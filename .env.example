# 백엔드 API base URL (context-path /api 포함)
VITE_API_BASE_URL=http://localhost:8080/api

# 포트원 V2 (Browser SDK 용). 콘솔에서 발급받은 값.
VITE_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 카카오 지도 JavaScript 키 (developers.kakao.com → 앱 → JavaScript 키)
# 도메인에 http://localhost:5173 등록 필요
VITE_KAKAO_MAP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx